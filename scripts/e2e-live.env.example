# Copy this file to ../.env.e2e (repo root) and fill it in. .env.e2e is git-ignored.
# These values are used ONLY by scripts/e2e-live.sh to run the live end-to-end test.

# Required
DOCMOST_BASE_URL=https://docs.example.com
DOCMOST_EMAIL=you@example.com
DOCMOST_PASSWORD=your-docmost-password

# Optional
# Pick a space explicitly; otherwise the first space from list_spaces is used.
# DOCMOST_SPACE_ID=018f0000-0000-7000-8000-000000000000
# Create the test page under an existing parent page (must be in the same space).
# DOCMOST_PARENT_PAGE_ID=
